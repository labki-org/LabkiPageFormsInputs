{
	"name": "labki-org/labki-page-forms-inputs",
	"type": "mediawiki-extension",
	"description": "Custom PageForms input types for date/time/timezone entry.",
	"license": "GPL-2.0-or-later",
	"homepage": "https://github.com/labki-org/LabkiPageFormsInputs",
	"authors": [
		{
			"name": "Aharoni Lab"
		}
	],
	"require": {
		"php": ">=8.1.0"
	},
	"require-dev": {
		"mediawiki/mediawiki-codesniffer": ">=44.0",
		"mediawiki/minus-x": ">=1.1.3",
		"php-parallel-lint/php-parallel-lint": ">=1.4.0"
	},
	"autoload": {
		"psr-4": {
			"Labki\\PageFormsInputs\\": "includes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Labki\\PageFormsInputs\\Tests\\": "tests/phpunit/"
		}
	},
	"scripts": {
		"test": [
			"parallel-lint . --exclude vendor --exclude node_modules --exclude resources/lib",
			"minus-x check .",
			"@phpcs"
		],
		"phpcs": "phpcs -p -s",
		"fix": [
			"minus-x fix .",
			"phpcbf"
		]
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"composer/installers": true
		},
		"platform": {
			"php": "8.1"
		}
	}
}
