{
	"name": "LabkiPageFormsInputs",
	"version": "0.2.0",
	"author": [
		"Aharoni Lab",
		"Daniel Aharoni"
	],
	"url": "https://github.com/labki-org/LabkiPageFormsInputs",
	"descriptionmsg": "labkipageformsinputs-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "other",
	"requires": {
		"MediaWiki": ">= 1.43.0",
		"extensions": {
			"PageForms": ">= 6.0"
		}
	},
	"AutoloadNamespaces": {
		"Labki\\PageFormsInputs\\": "includes/"
	},
	"MessagesDirs": {
		"LabkiPageFormsInputs": [
			"i18n"
		]
	},
	"Hooks": {
		"PageForms::FormPrinterSetup": "Labki\\PageFormsInputs\\Hooks::onPageFormsFormPrinterSetup",
		"BeforePageDisplay": "Labki\\PageFormsInputs\\Hooks::onBeforePageDisplay"
	},
	"ResourceFileModulePaths": {
		"localBasePath": "resources",
		"remoteExtPath": "LabkiPageFormsInputs/resources"
	},
	"ResourceModules": {
		"ext.labki.pfInputs.shared": {
			"scripts": [
				"modules/ext.labki.shared.js",
				"modules/ext.labki.tzData.js"
			],
			"styles": [
				"modules/ext.labki.styles.less"
			],
			"messages": [
				"labkipageformsinputs-tz-shortlist-label",
				"labkipageformsinputs-tz-all-zones",
				"labkipageformsinputs-tz-wiki-local"
			]
		},
		"ext.labki.pfInputs.datetime": {
			"scripts": [
				"modules/ext.labki.datetime.js"
			],
			"dependencies": [
				"ext.labki.pfInputs.shared",
				"ext.labki.pfInputs.flatpickr"
			],
			"messages": [
				"labkipageformsinputs-date-placeholder",
				"labkipageformsinputs-time-placeholder",
				"labkipageformsinputs-tz-placeholder",
				"labkipageformsinputs-tz-all-zones"
			]
		},
		"ext.labki.pfInputs.date": {
			"scripts": [
				"modules/ext.labki.date.js"
			],
			"dependencies": [
				"ext.labki.pfInputs.shared",
				"ext.labki.pfInputs.flatpickr"
			]
		},
		"ext.labki.pfInputs.time": {
			"scripts": [
				"modules/ext.labki.time.js"
			],
			"dependencies": [
				"ext.labki.pfInputs.shared",
				"ext.labki.pfInputs.flatpickr"
			],
			"messages": [
				"labkipageformsinputs-time-placeholder",
				"labkipageformsinputs-tz-placeholder",
				"labkipageformsinputs-tz-all-zones"
			]
		},
		"ext.labki.pfInputs.flatpickr": {
			"scripts": [
				"lib/flatpickr/flatpickr.min.js"
			],
			"styles": [
				"lib/flatpickr/flatpickr.min.css"
			]
		}
	},
	"config": {
		"LabkiPageFormsInputsTzShortlist": {
			"value": null,
			"description": "Override the curated TZ shortlist. Pass an associative PHP array `'IANA' => 'Display label'` (use '' for wiki-local). Order is preserved. Null/empty falls back to the bundled default."
		},
		"LabkiPageFormsInputsTime24h": {
			"value": true,
			"description": "Display the time picker in 24-hour mode (true) or 12-hour AM/PM mode (false). Storage format is always HH:MM regardless."
		},
		"LabkiPageFormsInputsFirstDayOfWeek": {
			"value": 1,
			"description": "First day of week shown in the date picker calendar: 0=Sunday, 1=Monday, ... 6=Saturday."
		},
		"LabkiPageFormsInputsDefaultTz": {
			"value": "",
			"description": "Fallback IANA timezone when a user has no `timecorrection` preference set. Empty string disables (widget defaults to wiki-local)."
		}
	},
	"manifest_version": 2
}
